{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "",
    "paths": {
      "@salt-ds/*": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@salt-ds/*"],
      "react": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@types/react"],
      "react/*": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@types/react/*"],
      "react/jsx-runtime": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@types/react/jsx-runtime"],
      "react-dom": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@types/react-dom"],
      "react-dom/client": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@types/react-dom/client"],
      "react-dom/*": ["../SmartDeviceManager/SmartDeviceManagerUI/node_modules/@types/react-dom/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["Components/**/*.ts", "Components/**/*.tsx"]
}
